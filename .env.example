# ── Copy this to .env and fill in your values ─────────────────────────────────
# cp .env.example .env

# App version (auto-set by CI/CD)
APP_VERSION=1.0.0

# MQTT
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Camera
CAMERA_INDEX=0
TARGET_FPS=15
JPEG_QUALITY=80
FRAME_WIDTH=640
FRAME_HEIGHT=480
ENABLE_LED=true
LED_GPIO_PIN=18

# Lane Detection
CANNY_LOW=50
CANNY_HIGH=150
HOUGH_THRESH=40
HOUGH_MIN_LEN=80
HOUGH_MAX_GAP=25

# Obstacle Detection
ULTRASONIC_TRIG=23
ULTRASONIC_ECHO=24
DANGER_DISTANCE_CM=30
WARN_DISTANCE_CM=60
MIN_OBSTACLE_AREA=800

# Traffic Light
TL_MIN_AREA=120
TL_CONFIRM_FRAMES=3

# Control
BASE_SPEED=55
SLOW_SPEED=30
TURN_GAIN=35
SERVO_CENTER=90
SERVO_MAX=140
SERVO_MIN=40
ENA_PIN=12
IN1_PIN=20
IN2_PIN=21
ENB_PIN=13
IN3_PIN=19
IN4_PIN=26
SERVO_PIN=17

# Grafana
GF_SECURITY_ADMIN_PASSWORD=autonomouscar
